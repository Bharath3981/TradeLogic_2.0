generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Instrument {
  id               Int     @id @default(autoincrement())
  instrument_token Int     @unique
  exchange_token   String?
  tradingsymbol    String?
  name             String?
  last_price       Float?
  expiry           DateTime?
  strike           Float?
  tick_size        Float?
  lot_size         Int?
  instrument_type  String?
  segment          String?
  exchange         String?
  updatedAt        DateTime @updatedAt
}
