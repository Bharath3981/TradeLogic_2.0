generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id
  email     String   @unique
  name      String?
  password  String
  kiteAccessToken String?  // Encrypted Kite Access Token
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  holdings  Holding[]
  watchlist Watchlist[]
  funds     Funds?
}

model Funds {
  id              String   @id @default(uuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id])
  availableCash   Float    @default(100000) // Default 1 Lakh for testing
  utilizedMargin  Float    @default(0)
  updatedAt       DateTime @updatedAt
}

// Models Order and Trade removed.


model Holding {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  tradingsymbol   String
  exchange        String
  instrumentToken String?
  quantity        Int
  averagePrice    Float
  product         String
}

model Watchlist {
  id              String   @id
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  watchlistSet    Int      // 1 to 7
  instrumentToken String
  exchangeToken   String?
  tradingsymbol   String
  name            String?
  lastPrice       Float    @default(0)
  expiry          String?
  strike          Float    @default(0)
  tickSize        Float    @default(0)
  lotSize         Int      @default(0)
  instrumentType  String?
  segment         String?
  exchange        String
  createdAt       DateTime @default(now())
}


// Models Position, AuditLog, and related Enums removed.


model Instrument {
  id               Int     @id @default(autoincrement())
  instrument_token Int     @unique
  exchange_token   String?
  tradingsymbol    String?
  name             String?
  last_price       Float?
  expiry           DateTime? 
  strike           Float?
  tick_size        Float?
  lot_size         Int?
  instrument_type  String?
  segment          String?
  exchange         String?
  updatedAt        DateTime @updatedAt
}



// Strategy and Trade models removed by User Request for clean architecture reset.

enum StrategyRunStatus {
  CREATED
  ENTRY_PLACING
  ENTRY_CONFIRMING
  ACTIVE
  ADJUSTING
  EXITING
  EXITED
  PAUSED
  ERROR
  @@map("strategy_run_status")
}

enum StrategyRunMode {
  MOCK
  REAL
  @@map("strategy_run_mode")
}

enum OptionLeg {
  CE
  PE
  @@map("option_leg")
}

enum PositionStatus {
  OPEN
  CLOSED
  @@map("position_status")
}

enum OrderSide {
  BUY
  SELL
  @@map("order_side")
}

enum OrderType {
  MARKET
  LIMIT
  @@map("order_type")
}

enum OrderStatus {
  CREATED
  PLACED
  PARTIALLY_FILLED
  FILLED
  CANCELLED
  REJECTED
  @@map("order_status")
}

enum ModuleExecStatus {
  STARTED
  SUCCEEDED
  FAILED
  SKIPPED
  RETRYING
  @@map("module_exec_status")
}

model Strategy {
  id          String   @id @db.VarChar(15)
  code        String   @unique
  name        String
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  moduleConfigs StrategyModuleConfig[]
  runs          StrategyRun[]

  @@map("strategies")
}

model StrategyModule {
  id           String   @id @db.VarChar(15)
  moduleKey    String   @unique @map("module_key")
  category     String
  description  String?
  inputSchema  Json?    @map("input_schema")
  outputSchema Json?    @map("output_schema")
  isActive     Boolean  @default(true) @map("is_active")
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  configs      StrategyModuleConfig[]

  @@map("strategy_modules")
}

model StrategyModuleConfig {
  id               String   @id @db.VarChar(15)
  strategyId       String         @map("strategy_id") @db.VarChar(15)
  strategy         Strategy       @relation(fields: [strategyId], references: [id], onDelete: Cascade)
  moduleKey        String         @map("module_key")
  moduleDef        StrategyModule @relation(fields: [moduleKey], references: [moduleKey])
  enabled          Boolean        @default(true)
  order            Int
  moduleConfigJson Json     @default("{}") @map("module_config_json")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  @@unique([strategyId, moduleKey], map: "uq_strategy_module")
  @@unique([strategyId, order], map: "uq_strategy_order")
  @@index([strategyId, enabled, order], map: "idx_strategy_module_configs")
  @@map("strategy_module_configs")
}

model StrategyRun {
  id              String            @id @db.VarChar(15)
  strategyId      String            @map("strategy_id") @db.VarChar(15)
  strategy        Strategy          @relation(fields: [strategyId], references: [id], onDelete: Restrict)
  status          StrategyRunStatus @default(CREATED)
  mode            StrategyRunMode   @default(MOCK)
  startedAt       DateTime          @default(now()) @map("started_at") @db.Timestamptz
  endedAt         DateTime?         @map("ended_at") @db.Timestamptz
  lockOwner       String?           @map("lock_owner")
  lastHeartbeatAt DateTime?         @map("last_heartbeat_at") @db.Timestamptz
  errorMessage    String?           @map("error_message")
  createdAt       DateTime          @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime          @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  state     StrategyRunState?
  events    StrategyRunEvent[]
  positions StrategyRunPosition[]
  orders    StrategyRunOrder[]

  @@index([status], map: "idx_strategy_runs_status")
  @@index([lastHeartbeatAt], map: "idx_strategy_runs_heartbeat")
  @@map("strategy_runs")
}

model StrategyRunState {
  runId        String      @id @map("run_id") @db.VarChar(15)
  run          StrategyRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  stateJson    Json        @map("state_json")
  stateVersion BigInt      @default(1) @map("state_version")
  updatedAt    DateTime    @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  @@map("strategy_run_state")
}

model StrategyRunEvent {
  id            String      @id @db.VarChar(15)
  runId         String      @map("run_id") @db.VarChar(15)
  run           StrategyRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  seq           BigInt
  eventType     String      @map("event_type")
  payloadJson   Json        @map("payload_json")
  correlationId String?     @map("correlation_id")
  createdAt     DateTime    @default(now()) @map("created_at") @db.Timestamptz

  @@unique([runId, seq], map: "uq_run_event_seq")
  @@index([runId, createdAt], map: "idx_strategy_run_events")
  @@map("strategy_run_events")
}

model StrategyRunPosition {
  id           String         @id @db.VarChar(15)
  runId        String         @map("run_id") @db.VarChar(15)
  run          StrategyRun    @relation(fields: [runId], references: [id], onDelete: Cascade)
  leg          OptionLeg
  strike       Int
  expiryDate   DateTime       @map("expiry_date") @db.Date
  instrumentToken String      @map("instrument_token")
  tradingsymbol   String      @map("tradingsymbol")
  exchange        String      @map("exchange")
  qty          Int
  entryPrice   Decimal        @map("entry_price") @db.Decimal(12, 4)
  exitPrice    Decimal?       @map("exit_price") @db.Decimal(12, 4)
  status       PositionStatus @default(OPEN)
  openedAt     DateTime       @default(now()) @map("opened_at") @db.Timestamptz
  closedAt     DateTime?      @map("closed_at") @db.Timestamptz
  openedReason String         @map("opened_reason")
  closedReason String?        @map("closed_reason")

  orders StrategyRunOrder[]

  @@index([runId, status], map: "idx_strategy_run_positions")
  @@map("strategy_run_positions")
}

model StrategyRunOrder {
  id               String               @id @db.VarChar(15)
  runId            String               @map("run_id") @db.VarChar(15)
  run              StrategyRun          @relation(fields: [runId], references: [id], onDelete: Cascade)
  positionId       String?              @map("position_id") @db.VarChar(15)
  position         StrategyRunPosition? @relation(fields: [positionId], references: [id])
  clientOrderId    String               @map("client_order_id")
  brokerOrderId    String?              @map("broker_order_id")
  side             OrderSide
  type             OrderType            @default(MARKET)
  status           OrderStatus          @default(CREATED)
  qty              Int
  requestedPrice   Decimal?             @map("requested_price") @db.Decimal(12, 4)
  filledPrice      Decimal?             @map("filled_price") @db.Decimal(12, 4)
  placedAt         DateTime?            @map("placed_at") @db.Timestamptz
  updatedAt        DateTime             @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  rawBrokerPayload Json?                @map("raw_broker_payload")

  @@unique([runId, clientOrderId], map: "uq_run_client_order")
  @@index([runId, status], map: "idx_strategy_run_orders")
  @@map("strategy_run_orders")
}

